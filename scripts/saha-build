#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"
# shellcheck source=saha-lib
. "$SCRIPT_DIR/saha-lib"

usage() {
  cat <<'USAGE'
Usage: scripts/saha-build <target>

Build a Saha robot image for a supported Jetson target inside Docker.
Run scripts/saha-robot-images to list image profiles and recipes.
Set SAHA_ROBOT_IMAGE=robot|robot-base|robot-ros|robot-docker to choose the image.
  robot (default)        saha-image-robot         ROS + Docker
  robot-base             saha-image-robot-base    base system only
  robot-ros              saha-image-robot-ros     ROS, no Docker
  robot-docker           saha-image-robot-docker  Docker, no ROS
Set SAHA_ROS_DISTRO=jazzy or SAHA_ROS_DISTRO=lyrical when the profile includes ROS 2.
HAVE_DOCKER_IMAGE and HAVE_ROS remain supported as legacy aliases for the profiles above.
Run scripts/saha-targets to list hardware targets.
USAGE
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

if [ $# -ne 1 ]; then
  usage >&2
  exit 2
fi

TARGET=$1
saha_require_target "$TARGET" >/dev/null
KAS_CONFIG="$(saha_kas_config_for_target "$TARGET")"
ROOT_DIR="$(saha_repo_root)"
saha_prepare_docker_env "$ROOT_DIR"
saha_apply_build_tuning_defaults

saha_build_builder_image "$ROOT_DIR"
saha_run_docker "$ROOT_DIR" "$TARGET" 0 kas build "$KAS_CONFIG"
