# Docker compose stack defaults. Override in /etc/default/saha-docker-compose.
SAHA_DOCKER_COMPOSE_DIR=/opt/roban/compose
SAHA_DOCKER_COMPOSE_FILE=/opt/roban/compose/compose.yaml
SAHA_DOCKER_COMPOSE_ENV=/etc/default/saha-docker-compose
SAHA_DOCKER_COMPOSE_TZ=Asia/Shanghai
SAHA_DOCKER_COMPOSE_PULL=0
SAHA_DOCKER_COMPOSE_WAIT=60
SAHA_HOMEASSISTANT_IMAGE=ghcr.io/home-assistant/home-assistant:stable
SAHA_HOMEASSISTANT_IMAGE_TAR=/usr/share/saha/homeassistant/image.tar
SAHA_MATTER_SERVER_IMAGE=ghcr.io/matter-js/python-matter-server:arm64
SAHA_MATTER_SERVER_IMAGE_TAR=/usr/share/saha/matter-server/image.tar
SAHA_ROBAN_WORKFLOW_IMAGE=roban-workflow-api:arm64
SAHA_ROBAN_WORKFLOW_IMAGE_TAR=/usr/share/saha/roban-workflow-api/image.tar
