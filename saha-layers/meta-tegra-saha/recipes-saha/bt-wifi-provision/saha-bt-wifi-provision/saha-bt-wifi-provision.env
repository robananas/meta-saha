# Roban Bluetooth WiFi provisioning defaults.
SAHA_BT_WIFI_LOCAL_NAME=Roban-Bluetooth
SAHA_BT_WIFI_ADAPTER_WAIT=45
# Development-only identities are bundled into the image to bring up BLE v2.
# Replace them with manufacturing/CI-injected credentials before production.
ROBAN_DEVICE_IDENTITY_FILE=/etc/roban/ble-device-ed25519.key
ROBAN_APP_KEYRING_FILE=/etc/roban/ble-app-keyring.json
